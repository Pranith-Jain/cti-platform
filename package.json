{
  "name": "cti-platform",
  "version": "2.0.0",
  "description": "CTI Platform — Threat intelligence surface on the edge (React + Vite + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "build": "npm run build:client && npm run build:server",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "analyze": "vite build --mode analyze",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "exifr": "^7.1.3",
    "isomorphic-dompurify": "^3.12.0",
    "lucide-react": "^0.468.0",
    "marked": "^14.1.4",
    "preact": "^10.29.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "react-simple-maps": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.0.11",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.49",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^4.88.0"
  },
  "keywords": [
    "threat-intelligence",
    "cti",
    "react",
    "vite",
    "tailwind",
    "cloudflare-workers"
  ],
  "author": "Pranith Jain",
  "license": "MIT"
}
