# Minimal client-only Tor config for the onion-proxy.
# We only need SOCKS5 on localhost — no relay, no exit, no hidden services.

SocksPort 9050
SocksPolicy accept 127.0.0.1
SocksPolicy reject *

# Quieter logs; we don't want path-level info in our logs either.
Log notice file /var/log/tor/notices.log
DataDirectory /var/lib/tor

# Faster startup, fewer guards = less metadata noise on a low-traffic client.
ClientUseIPv6 1
SafeLogging 1
AvoidDiskWrites 1
